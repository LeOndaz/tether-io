# Gateway
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Ollama
OLLAMA_URL=http://localhost:11434

# Model Runtime (ollama | docker | vllm | remote)
MODEL_RUNTIME=ollama

# Hyperswarm
CLUSTER_TOPIC=ai-paas-cluster-v1

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MIN=60
RATE_LIMIT_TOKENS_PER_HOUR=100000

# Worker
WORKER_ID=worker-1
