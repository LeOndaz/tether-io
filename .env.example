# Gateway
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MIN=60
RATE_LIMIT_TOKENS_PER_HOUR=100000

# Session Auth
SESSION_SECRET=change-me-to-a-very-long-secret-phrase-at-least-32-chars
SESSION_SALT=aipaas-salt-16ch
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# DHT Bootstrap (optional, for Docker networking)
# DHT_BOOTSTRAP=dht-bootstrap:49737

# Frontend URL (optional, for CORS in production)
# FRONTEND_URL=https://your-frontend.example.com

# Worker
WORKER_ID=worker-1
OLLAMA_URL=http://localhost:11434
MODEL_RUNTIME=ollama
CLUSTER_TOPIC=ai-paas-cluster-v1
